# ============================================================
# .env - Environment Variable Defaults for Docker Compose
# ============================================================
# Copy this file and customize values for your environment.
# NEVER commit secrets to version control.
# ============================================================

# Host port to expose the service on (default: 8080)
HOST_PORT=8080

# Alpha Vantage API Key
# Get a FREE key at: https://www.alphavantage.co/support/#api-key
# Replace 'demo' below with your key for full live stock data
ALPHA_VANTAGE_API_KEY=demo

# Spring active profile (default | prod)
SPRING_PROFILES_ACTIVE=default
