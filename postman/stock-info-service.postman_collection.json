    {
      "name": "Stock Lookup - POST (by body)",
      "description": "POST endpoint that accepts a JSON request body containing either a ticker symbol (e.g., `AAPL`) or a company name (e.g., `Apple`). This is the primary endpoint.",
      "item": [
        {
          "name": "Lookup by Ticker - AAPL (Apple)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has required stock fields\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('symbol');",
                  "    pm.expect(json).to.have.property('companyName');",
                  "    pm.expect(json).to.have.property('price');",
                  "    pm.expect(json).to.have.property('change');",
                  "    pm.expect(json).to.have.property('changePercent');",
                  "    pm.expect(json).to.have.property('volume');",
                  "    pm.expect(json).to.have.property('dataSource');",
                  "});",
                  "",
                  "pm.test(\"Symbol is AAPL\", function () {",
                  "    pm.expect(pm.response.json().symbol).to.eql(\"AAPL\");",
                  "});",
                  "",
                  "pm.test(\"Price is a positive number\", function () {",
                  "    pm.expect(pm.response.json().price).to.be.above(0);",
                  "});",
                  "",
                  "// Store the price for use in other requests",
                  "const price = pm.response.json().price;",
                  "pm.environment.set('lastLookedUpPrice', price);",
                  "console.log('AAPL price stored:', price);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"query\": \"AAPL\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/stocks/lookup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stocks", "lookup"]
            },
            "description": "Fetches stock details for Apple Inc. (AAPL) by ticker symbol."
          },
          "response": [
