    {
      "name": "Error Scenarios",
      "description": "Tests for expected error responses — validations, not-found cases, and malformed requests.",
      "item": [
        {
          "name": "Validation - Empty Query",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Error is Validation Failed\", function () {",
                  "    pm.expect(pm.response.json().error).to.eql(\"Validation Failed\");",
                  "});",
                  "pm.test(\"Validation errors present\", function () {",
                  "    pm.expect(pm.response.json()).to.have.property('validationErrors');",
                  "    pm.expect(pm.response.json().validationErrors).to.have.property('query');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
